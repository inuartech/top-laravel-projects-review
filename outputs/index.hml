<title>Laravel Engineering Portfolio Review — June 2026</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
:root {
  --ground:   #080D18;
  --surface:  #0F1628;
  --surface2: #172040;
  --border:   #1E2E52;
  --text:     #C8D4E8;
  --muted:    #5A6E92;
  --accent:   #5865F2;
  --amber:    #E89823;
  --emerald:  #3DD68C;
  --rose:     #F4615B;
  --mono: ui-monospace,'Cascadia Code','Source Code Pro',Menlo,monospace;
  --sans: -apple-system,BlinkMacSystemFont,'Segoe UI',system-ui,sans-serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{
  background:var(--ground);
  color:var(--text);
  font-family:var(--sans);
  font-size:16px;
  line-height:1.65;
  -webkit-font-smoothing:antialiased;
}
a{color:var(--accent);text-decoration:none}
a:hover{text-decoration:underline}

/* LAYOUT */
.wrap{max-width:1160px;margin:0 auto;padding:0 24px}
section{padding:80px 0}
section+section{border-top:1px solid var(--border)}

/* TYPOGRAPHY */
.eyebrow{
  font-family:var(--mono);
  font-size:11px;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--accent);
  margin-bottom:16px;
}
h1{
  font-family:var(--mono);
  font-size:clamp(2.4rem,6vw,4.8rem);
  font-weight:700;
  line-height:1.05;
  color:#fff;
  letter-spacing:-0.03em;
}
h2{
  font-family:var(--mono);
  font-size:clamp(1.4rem,3vw,2rem);
  font-weight:700;
  color:#fff;
  letter-spacing:-0.02em;
  margin-bottom:32px;
}
h3{
  font-size:1rem;
  font-weight:600;
  color:#fff;
  margin-bottom:12px;
}
p{color:var(--text);line-height:1.75}

/* HEADER */
header{
  background:linear-gradient(180deg,#0d1528 0%,var(--ground) 100%);
  border-bottom:1px solid var(--border);
  padding:80px 0 64px;
}
.header-meta{
  display:flex;
  align-items:center;
  gap:24px;
  margin-bottom:40px;
  font-family:var(--mono);
  font-size:12px;
  color:var(--muted);
}
.header-meta span{display:flex;align-items:center;gap:6px}
.header-meta span::before{content:'';display:block;width:4px;height:4px;border-radius:50%;background:var(--accent)}
.header-meta span:first-child::before{display:none}

.hero-lead{
  max-width:640px;
  margin:24px 0 48px;
  font-size:1.1rem;
  color:var(--muted);
}

.stats-strip{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:1px;
  background:var(--border);
  border:1px solid var(--border);
  border-radius:8px;
  overflow:hidden;
  margin-top:48px;
}
.stat-cell{
  background:var(--surface);
  padding:20px 24px;
  text-align:center;
}
.stat-num{
  font-family:var(--mono);
  font-size:1.8rem;
  font-weight:700;
  color:#fff;
  display:block;
  letter-spacing:-0.04em;
}
.stat-label{
  font-size:11px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--muted);
  margin-top:4px;
}

/* MINI LEADERBOARD GRID */
.mini-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:1px;
  background:var(--border);
  border:1px solid var(--border);
  border-radius:8px;
  overflow:hidden;
  margin-top:48px;
}
.mini-card{
  background:var(--surface);
  padding:16px 20px;
  cursor:pointer;
  transition:background 0.15s;
  position:relative;
  overflow:hidden;
}
.mini-card:hover{background:var(--surface2)}
.mini-rank{
  position:absolute;
  right:12px;
  top:50%;
  transform:translateY(-50%);
  font-family:var(--mono);
  font-size:3.5rem;
  font-weight:700;
  opacity:0.06;
  color:#fff;
  line-height:1;
  pointer-events:none;
}
.mini-name{
  font-family:var(--mono);
  font-size:14px;
  font-weight:600;
  color:#fff;
  margin-bottom:6px;
}
.mini-score{
  font-family:var(--mono);
  font-size:1.5rem;
  font-weight:700;
  line-height:1;
}
.mini-tag{
  font-size:10px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--muted);
  margin-top:6px;
}

/* SCORE COLORS */
.score-great{color:var(--emerald)}
.score-good{color:#F0C040}
.score-poor{color:var(--rose)}
.badge-great{background:rgba(61,214,140,0.12);color:var(--emerald)}
.badge-good{background:rgba(240,192,64,0.12);color:#F0C040}
.badge-poor{background:rgba(244,97,91,0.12);color:var(--rose)}

/* RANKING TABLE */
.rank-table{
  width:100%;
  border-collapse:collapse;
  font-size:14px;
}
.rank-table th{
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
  text-align:left;
  padding:12px 16px;
  border-bottom:1px solid var(--border);
  white-space:nowrap;
}
.rank-table th:not(:first-child){text-align:center}
.rank-table td{
  padding:0;
  border-bottom:1px solid var(--border);
  vertical-align:middle;
}
.rank-table tbody tr:hover .row-inner{background:var(--surface2)}
.row-inner{
  display:grid;
  grid-template-columns:48px 1fr 120px repeat(6,52px) 80px 70px;
  align-items:center;
  padding:14px 16px;
  gap:0;
  transition:background 0.12s;
  cursor:pointer;
}
.rank-num{
  font-family:var(--mono);
  font-weight:700;
  font-size:20px;
  color:var(--muted);
  text-align:left;
  min-width:48px;
}
.rank-1 .rank-num{color:var(--emerald)}
.rank-2 .rank-num{color:var(--emerald);opacity:0.7}
.rank-3 .rank-num{color:var(--emerald);opacity:0.5}
.proj-name{
  font-family:var(--mono);
  font-weight:600;
  font-size:15px;
  color:#fff;
}
.proj-maintainer{
  font-size:11px;
  color:var(--muted);
  margin-top:2px;
}
.overall-score{
  font-family:var(--mono);
  font-weight:700;
  font-size:22px;
  text-align:center;
  padding:0 8px;
}
.dim-badge{
  font-family:var(--mono);
  font-weight:700;
  font-size:13px;
  text-align:center;
  padding:4px 0;
  border-radius:4px;
  margin:0 3px;
  min-width:38px;
  display:inline-block;
}
.phpstan-cell{
  font-family:var(--mono);
  font-size:12px;
  text-align:right;
  color:var(--muted);
  padding-right:4px;
}
.activity-cell{
  font-family:var(--mono);
  font-size:12px;
  text-align:right;
  color:var(--muted);
}
.score-bar-wrap{
  width:80px;
  height:4px;
  background:var(--border);
  border-radius:2px;
  overflow:hidden;
}
.score-bar-fill{
  height:100%;
  border-radius:2px;
  transition:width 0.6s ease;
}

/* TABLE DIM HEADINGS */
.dim-th{text-align:center!important;width:52px}

/* ACCORDION */
.proj-accordion{display:flex;flex-direction:column;gap:1px;background:var(--border);border-radius:8px;overflow:hidden}
.proj-item{}
.proj-trigger{
  width:100%;
  display:grid;
  grid-template-columns:1fr auto;
  align-items:center;
  padding:20px 24px;
  background:var(--surface);
  border:none;
  color:var(--text);
  cursor:pointer;
  text-align:left;
  transition:background 0.12s;
}
.proj-trigger:hover{background:var(--surface2)}
.proj-trigger.active{background:var(--surface2)}
.trigger-left{display:flex;align-items:center;gap:16px}
.trigger-rank{
  font-family:var(--mono);
  font-size:11px;
  font-weight:700;
  color:var(--muted);
  letter-spacing:0.05em;
  min-width:28px;
}
.trigger-name{
  font-family:var(--mono);
  font-size:16px;
  font-weight:700;
  color:#fff;
}
.trigger-tag{
  font-size:11px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  padding:2px 8px;
  border-radius:3px;
  background:var(--surface2);
  color:var(--muted);
}
.trigger-right{display:flex;align-items:center;gap:20px}
.trigger-score{
  font-family:var(--mono);
  font-size:24px;
  font-weight:700;
}
.trigger-chevron{
  color:var(--muted);
  transition:transform 0.2s;
  flex-shrink:0;
}
.proj-trigger.active .trigger-chevron{transform:rotate(180deg)}

.proj-panel{
  display:none;
  background:var(--ground);
  padding:32px 24px;
  border-top:1px solid var(--border);
}
.proj-panel.open{display:block}

/* SCORECARD GRID */
.scorecard-grid{
  display:grid;
  grid-template-columns:repeat(6,1fr);
  gap:1px;
  background:var(--border);
  border-radius:8px;
  overflow:hidden;
  margin-bottom:32px;
}
.score-cell{
  background:var(--surface);
  padding:16px;
  text-align:center;
}
.score-cell-label{
  font-size:10px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:8px;
}
.score-cell-num{
  font-family:var(--mono);
  font-size:2.4rem;
  font-weight:700;
  line-height:1;
}

.detail-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
  margin-top:24px;
}
.detail-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:20px;
}
.detail-card h4{
  font-family:var(--mono);
  font-size:11px;
  letter-spacing:0.1em;
  text-transform:uppercase;
  color:var(--muted);
  margin-bottom:12px;
}
.detail-card ul{
  list-style:none;
  display:flex;
  flex-direction:column;
  gap:8px;
}
.detail-card li{
  font-size:13px;
  color:var(--text);
  padding-left:16px;
  position:relative;
  line-height:1.5;
}
.detail-card li::before{
  content:'';
  position:absolute;
  left:0;
  top:8px;
  width:5px;
  height:5px;
  border-radius:50%;
}
.strengths li::before{background:var(--emerald)}
.weaknesses li::before{background:var(--amber)}
.risks li::before{background:var(--rose)}
.recs li::before{background:var(--accent)}

.phpstan-strip{
  display:grid;
  grid-template-columns:1fr 1fr 1fr 1fr;
  gap:1px;
  background:var(--border);
  border-radius:8px;
  overflow:hidden;
  margin-top:24px;
}
.phpstan-cell-inner{
  background:var(--surface);
  padding:14px 18px;
  text-align:center;
}
.phpstan-cell-num{
  font-family:var(--mono);
  font-size:1.4rem;
  font-weight:700;
  color:#fff;
}
.phpstan-cell-label{
  font-size:10px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--muted);
  margin-top:4px;
}

/* INSIGHTS */
.insights-grid{
  display:grid;
  grid-template-columns:1fr 1fr;
  gap:24px;
}
.insight-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:28px;
}
.insight-card.accent-amber{border-color:rgba(232,152,35,0.35)}
.insight-card.accent-emerald{border-color:rgba(61,214,140,0.35)}
.insight-card.accent-rose{border-color:rgba(244,97,91,0.35)}
.insight-card.accent-blue{border-color:rgba(88,101,242,0.35)}
.insight-icon{
  font-size:24px;
  margin-bottom:12px;
}
.insight-card h3{
  font-family:var(--mono);
  font-size:14px;
  letter-spacing:0.04em;
  color:#fff;
  margin-bottom:12px;
}
.insight-card p,.insight-card li{
  font-size:13px;
  color:var(--muted);
  line-height:1.65;
}
.insight-card ul{list-style:none;display:flex;flex-direction:column;gap:6px}
.insight-card li{padding-left:14px;position:relative}
.insight-card li::before{content:'→';position:absolute;left:0;color:var(--accent);font-size:11px;top:2px}

/* CONTRIBUTORS */
.contrib-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(220px,1fr));
  gap:16px;
}
.contrib-card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:8px;
  padding:20px;
}
.contrib-name{
  font-family:var(--mono);
  font-size:14px;
  font-weight:700;
  color:#fff;
  margin-bottom:4px;
}
.contrib-handle{
  font-family:var(--mono);
  font-size:11px;
  color:var(--accent);
  margin-bottom:8px;
}
.contrib-project{
  font-size:12px;
  color:var(--muted);
  margin-bottom:12px;
}
.contrib-stat{
  display:flex;
  justify-content:space-between;
  align-items:center;
  font-size:12px;
  padding:4px 0;
  border-top:1px solid var(--border);
}
.contrib-stat:first-of-type{margin-top:12px}
.contrib-stat-label{color:var(--muted)}
.contrib-stat-value{
  font-family:var(--mono);
  font-weight:700;
  color:#fff;
}
.contrib-why{
  font-size:12px;
  color:var(--muted);
  margin-top:12px;
  line-height:1.6;
  padding-top:12px;
  border-top:1px solid var(--border);
}

/* LESSONS */
.lessons-grid{
  display:flex;
  flex-direction:column;
  gap:24px;
}
.lesson-item{
  display:grid;
  grid-template-columns:48px 1fr;
  gap:20px;
  align-items:start;
}
.lesson-num{
  font-family:var(--mono);
  font-size:2rem;
  font-weight:700;
  color:var(--border);
  line-height:1.2;
}
.lesson-title{
  font-family:var(--mono);
  font-size:15px;
  font-weight:700;
  color:#fff;
  margin-bottom:8px;
}
.lesson-body{font-size:14px;color:var(--muted);line-height:1.75}

/* FOOTER */
footer{
  border-top:1px solid var(--border);
  padding:40px 0;
  background:var(--surface);
}
.footer-inner{
  display:flex;
  justify-content:space-between;
  align-items:center;
  flex-wrap:wrap;
  gap:16px;
}
.footer-note{font-size:12px;color:var(--muted);font-family:var(--mono)}

/* RESPONSIVE */
@media(max-width:900px){
  .stats-strip{grid-template-columns:repeat(2,1fr)}
  .row-inner{grid-template-columns:40px 1fr 90px repeat(6,40px) 60px;font-size:13px}
  .insights-grid{grid-template-columns:1fr}
  .detail-grid{grid-template-columns:1fr}
  .scorecard-grid{grid-template-columns:repeat(3,1fr)}
  .phpstan-strip{grid-template-columns:1fr 1fr}
  .mini-grid{grid-template-columns:repeat(auto-fill,minmax(160px,1fr))}
}
@media(max-width:640px){
  h1{font-size:2rem}
  .row-inner{
    grid-template-columns:32px 1fr 70px;
    font-size:13px;
  }
  .dim-cols{display:none}
  .phpstan-col{display:none}
  .activity-col{display:none}
  .stats-strip{grid-template-columns:1fr 1fr}
  .contrib-grid{grid-template-columns:1fr}
}

/* NAV */
.sticky-nav{
  position:sticky;
  top:0;
  z-index:100;
  background:rgba(8,13,24,0.92);
  backdrop-filter:blur(12px);
  border-bottom:1px solid var(--border);
  padding:0 24px;
}
.nav-inner{
  max-width:1160px;
  margin:0 auto;
  display:flex;
  gap:0;
  align-items:center;
  overflow-x:auto;
}
.nav-link{
  font-family:var(--mono);
  font-size:12px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  color:var(--muted);
  padding:16px 20px;
  border-bottom:2px solid transparent;
  white-space:nowrap;
  text-decoration:none;
  transition:color 0.15s, border-color 0.15s;
}
.nav-link:hover{color:#fff;text-decoration:none;border-color:var(--accent)}
.nav-wordmark{
  font-family:var(--mono);
  font-size:13px;
  font-weight:700;
  color:#fff;
  margin-right:24px;
  white-space:nowrap;
  padding:16px 0;
}

/* SCORE BAR ANIMATION */
@keyframes barIn{from{width:0}to{width:var(--bar-w)}}
.score-bar-fill.animate{animation:barIn 0.8s ease forwards}

/* PATTERN TAGS */
.pattern-tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:12px}
.pattern-tag{
  font-family:var(--mono);
  font-size:10px;
  letter-spacing:0.06em;
  padding:3px 8px;
  border-radius:3px;
  background:var(--surface2);
  color:var(--muted);
  border:1px solid var(--border);
}

/* RED FLAG STRIP */
.red-flag{
  display:flex;
  align-items:start;
  gap:12px;
  padding:16px;
  background:rgba(244,97,91,0.06);
  border:1px solid rgba(244,97,91,0.25);
  border-radius:6px;
  margin-top:16px;
}
.red-flag-icon{color:var(--rose);flex-shrink:0;margin-top:2px}
.red-flag-text{font-size:13px;color:var(--muted);line-height:1.6}
.red-flag-text strong{color:var(--rose)}
</style>

<!-- NAV -->
<nav class="sticky-nav">
  <div class="nav-inner">
    <span class="nav-wordmark">⚡ PHP Review</span>
    <a href="#rankings" class="nav-link">Rankings</a>
    <a href="#projects" class="nav-link">Scorecards</a>
    <a href="#insights" class="nav-link">Insights</a>
    <a href="#contributors" class="nav-link">Who to Follow</a>
    <a href="#lessons" class="nav-link">Lessons</a>
  </div>
</nav>

<!-- HEADER -->
<header>
  <div class="wrap">
    <div class="header-meta">
      <span>June 2026</span>
      <span>11 Projects</span>
      <span>PHPStan 2.2.2</span>
      <span>PHP 8.4 · Larastan 3.x</span>
    </div>

    <div class="eyebrow">Open-Source Laravel Engineering Portfolio Review</div>
    <h1>Who's building<br>Laravel right?</h1>
    <p class="hero-lead">
      We put 11 open-source Laravel codebases through static analysis, architecture review,
      and git forensics. Six dimensions. One weighted score. Opinions included.
    </p>

    <div class="stats-strip">
      <div class="stat-cell">
        <span class="stat-num score-great">11</span>
        <div class="stat-label">Projects Analysed</div>
      </div>
      <div class="stat-cell">
        <span class="stat-num">2.6M</span>
        <div class="stat-label">Total Lines of Code</div>
      </div>
      <div class="stat-cell">
        <span class="stat-num">2,547</span>
        <div class="stat-label">Commits (90 days)</div>
      </div>
      <div class="stat-cell">
        <span class="stat-num score-poor">68,220</span>
        <div class="stat-label">PHPStan Errors Found</div>
      </div>
    </div>

    <!-- MINI LEADERBOARD -->
    <div class="mini-grid" style="margin-top:40px">
      <div class="mini-card" onclick="openProject('koel')">
        <div class="mini-rank">1</div>
        <div class="mini-name">koel</div>
        <div class="mini-score score-great">8.70</div>
        <div class="mini-tag">Architecture Reference</div>
      </div>
      <div class="mini-card" onclick="openProject('subscriptionify')">
        <div class="mini-rank">2</div>
        <div class="mini-name">subscriptionify</div>
        <div class="mini-score score-great">8.20</div>
        <div class="mini-tag">Package Gold Standard</div>
      </div>
      <div class="mini-card" onclick="openProject('monica')">
        <div class="mini-rank">3</div>
        <div class="mini-name">monica</div>
        <div class="mini-score score-great">7.95</div>
        <div class="mini-tag">DDD Reference</div>
      </div>
      <div class="mini-card" onclick="openProject('bookstack')">
        <div class="mini-rank">4</div>
        <div class="mini-name">bookstack</div>
        <div class="mini-score score-great">7.70</div>
        <div class="mini-tag">Solo Maintainer Excellence</div>
      </div>
      <div class="mini-card" onclick="openProject('october')">
        <div class="mini-rank">5</div>
        <div class="mini-name">october</div>
        <div class="mini-score" style="color:#F0C040">7.15</div>
        <div class="mini-tag">CMS Architecture</div>
      </div>
      <div class="mini-card" onclick="openProject('invoiceninja')">
        <div class="mini-rank">6</div>
        <div class="mini-name">invoiceninja</div>
        <div class="mini-score" style="color:#F0C040">6.85</div>
        <div class="mini-tag">Highest Activity</div>
      </div>
      <div class="mini-card" onclick="openProject('bagisto')">
        <div class="mini-rank">7</div>
        <div class="mini-name">bagisto</div>
        <div class="mini-score" style="color:#F0C040">6.80</div>
        <div class="mini-tag">Commerce Platform</div>
      </div>
      <div class="mini-card" onclick="openProject('coolify')">
        <div class="mini-rank">8</div>
