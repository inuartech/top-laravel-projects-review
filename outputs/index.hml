function scoreClass(s){
  if(s>=8)return'score-great';
  if(s>=6.5)return'';
  return'score-poor';
}
function dimBadgeClass(s){
  if(s>=8)return'badge-great';
  if(s>=6)return'badge-good';
  return'badge-poor';
}
function scoreColor(s){
  if(s>=8)return'var(--emerald)';
  if(s>=6.5)return'#F0C040';
  return'var(--rose)';
}
function dimColor(s){
  if(s>=8)return'var(--emerald)';
  if(s>=6)return'#F0C040';
  return'var(--rose)';
}
function fmtErrors(n){
  if(n===0)return'—';
  if(n>=1000)return(n/1000).toFixed(1)+'K';
  return n.toString();
}

// Build ranking table
(function(){
  const tbody = document.getElementById('rankTableBody');
  P.forEach(p=>{
    const barW = (p.overall/10*100).toFixed(1)+'%';
    const tr = document.createElement('tr');
    tr.className='rank-'+p.rank;
    tr.onclick=()=>openProject(p.slug);
    tr.innerHTML=`
      <td>
        <div class="row-inner">
          <div class="rank-num">${String(p.rank).padStart(2,'0')}</div>
          <div>
            <div class="proj-name">${p.name}</div>
            <div class="proj-maintainer">${p.maintainer}</div>
          </div>
          <div class="overall-score" style="color:${scoreColor(p.overall)}">${p.overall.toFixed(2)}</div>
          <div class="dim-badge ${dimBadgeClass(p.arch)} dim-cols">${p.arch}</div>
          <div class="dim-badge ${dimBadgeClass(p.qual)} dim-cols">${p.qual}</div>
          <div class="dim-badge ${dimBadgeClass(p.maint)} dim-cols">${p.maint}</div>
          <div class="dim-badge ${dimBadgeClass(p.patt)} dim-cols">${p.patt}</div>
          <div class="dim-badge ${dimBadgeClass(p.debt)} dim-cols">${p.debt}</div>
          <div class="dim-badge ${dimBadgeClass(p.act)} dim-cols">${p.act}</div>
          <div class="phpstan-cell phpstan-col">${fmtErrors(p.phpstanErrors)}</div>
          <div class="activity-cell activity-col">${p.commits90d}</div>
        </div>
      </td>`;
    tbody.appendChild(tr);
  });
})();

// Build accordion
(function(){
  const acc = document.getElementById('accordion');
  P.forEach(p=>{
    const item = document.createElement('div');
    item.className='proj-item';
    item.id='proj-'+p.slug;

    const dims=[
      {label:'Architecture',val:p.arch},
      {label:'Code Quality',val:p.qual},
      {label:'Maintainability',val:p.maint},
      {label:'Design Patterns',val:p.patt},
      {label:'Tech Debt',val:p.debt},
      {label:'Activity',val:p.act}
    ];

    const scoreGridHtml=dims.map(d=>`
      <div class="score-cell">
        <div class="score-cell-label">${d.label}</div>
        <div class="score-cell-num" style="color:${dimColor(d.val)}">${d.val}</div>
      </div>`).join('');

    const strHtml=p.strengths.map(s=>`<li>${s}</li>`).join('');
    const wkHtml=p.weaknesses.map(s=>`<li>${s}</li>`).join('');
    const rkHtml=p.risks.map(s=>`<li>${s}</li>`).join('');
    const rcHtml=p.recs.map(s=>`<li>${s}</li>`).join('');
    const ptHtml=p.patterns.map(t=>`<span class="pattern-tag">${t}</span>`).join('');

    item.innerHTML=`
      <button class="proj-trigger" onclick="toggleProject('${p.slug}')">
        <div class="trigger-left">
          <div class="trigger-rank">#${p.rank}</div>
          <div class="trigger-name">${p.name}</div>
          <div class="trigger-tag">${p.tag}</div>
        </div>
        <div class="trigger-right">
          <div class="trigger-score" style="color:${scoreColor(p.overall)}">${p.overall.toFixed(2)}</div>
          <svg class="trigger-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
      </button>
      <div class="proj-panel" id="panel-${p.slug}">
        <p style="color:var(--muted);font-size:14px;margin-bottom:20px;line-height:1.75">${p.summary}</p>
        <div class="pattern-tags">${ptHtml}</div>

        <div class="scorecard-grid" style="margin-top:20px">${scoreGridHtml}</div>

        <div class="phpstan-strip">
          <div class="phpstan-cell-inner">
            <div class="phpstan-cell-num">${fmtErrors(p.phpstanErrors)}</div>
            <div class="phpstan-cell-label">PHPStan Errors</div>
          </div>
          <div class="phpstan-cell-inner">
            <div class="phpstan-cell-num">${p.phpstanDensity.toFixed(1)}</div>
            <div class="phpstan-cell-label">Errors / KLOC</div>
          </div>
          <div class="phpstan-cell-inner">
            <div class="phpstan-cell-num">${p.loc}</div>
            <div class="phpstan-cell-label">Lines of Code</div>
          </div>
          <div class="phpstan-cell-inner">
            <div class="phpstan-cell-num">${p.testFiles}</div>
            <div class="phpstan-cell-label">Test Files</div>
          </div>
        </div>

        <div class="detail-grid">
          <div class="detail-card">
            <h4>Strengths</h4>
            <ul class="strengths">${strHtml}</ul>
          </div>
          <div class="detail-card">
            <h4>Weaknesses</h4>
            <ul class="weaknesses">${wkHtml}</ul>
          </div>
          <div class="detail-card">
            <h4>Key Risks</h4>
            <ul class="risks">${rkHtml}</ul>
          </div>
          <div class="detail-card">
            <h4>Recommendations</h4>
            <ul class="recs">${rcHtml}</ul>
          </div>
        </div>

        <div style="margin-top:16px;display:flex;gap:16px;font-family:var(--mono);font-size:12px;color:var(--muted)">
          <span>Laravel ${p.laravel}</span>
          <span>·</span>
          <span>${p.commits90d} commits / 90d</span>
          <span>·</span>
          <span>${p.contributors90d} contributors / 90d</span>
        </div>
      </div>`;

    acc.appendChild(item);
  });
})();

function toggleProject(slug){
  const panel=document.getElementById('panel-'+slug);
  const trigger=panel.previousElementSibling;
  const isOpen=panel.classList.contains('open');
  panel.classList.toggle('open',!isOpen);
  trigger.classList.toggle('active',!isOpen);
}

function openProject(slug){
  const target=document.getElementById('proj-'+slug);
  if(!target)return;
  target.scrollIntoView({behavior:'smooth',block:'start'});
  setTimeout(()=>{
    const panel=document.getElementById('panel-'+slug);
    if(!panel.classList.contains('open')){
      panel.classList.add('open');
      panel.previousElementSibling.classList.add('active');
    }
  },300);
}

// Animate score bars on scroll
const observer=new IntersectionObserver(entries=>{
  entries.forEach(e=>{
    if(e.isIntersecting){
      e.target.querySelectorAll('.score-bar-fill').forEach(b=>b.classList.add('animate'));
    }
  });
},{threshold:0.1});
document.querySelectorAll('.rank-table tbody tr').forEach(r=>observer.observe(r));
</script>
